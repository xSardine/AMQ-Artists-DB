# Copy this file to ".env" in this folder (backEnd/.env) before starting the server.
# See backEnd/README.md.

# URL path segment for the in-memory request log viewer.
# Viewer:  http://127.0.0.1:8000/<segment>
# JSON:     http://127.0.0.1:8000/<segment>/feed
# Omit or leave blank to use the default "log". Use a non-obvious value in production.
REQUEST_LOG_URL_SEGMENT=log
